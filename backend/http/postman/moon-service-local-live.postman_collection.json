              "raw": "{\n  \"locationId\": \"prague-cz\",\n  \"start\": \"2026-06-29\",\n  \"forecastHorizonDays\": 7,\n  \"maxMoonAltitudeDegrees\": 12,\n  \"limit\": 5\n}",
              "options": {
                "raw": {
