      "value": "Zakopane"
    },
    {
      "key": "ambiguousQuery",
      "value": "Springfield"
    },
    {
      "key": "notFoundQuery",
      "value": "MoonServiceDefinitelyNotAPlace"
    },
    {
      "key": "tooLongQuery",
      "value": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    }
  ],
  "item": [
