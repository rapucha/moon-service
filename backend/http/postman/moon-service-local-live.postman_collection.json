        {
          "name": "Resolved live lookup",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/opportunities?q={{resolvedQuery}}",
              "variable": [],
              "path": [
                "api",
                "opportunities"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "{{resolvedQuery}}"
                }
              ]
            },
            "description": "Expected product state: ok, unless the live provider is unavailable or changes behavior."
          }
        },
